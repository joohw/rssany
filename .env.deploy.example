# 部署凭据模板 — 复制为 .env.deploy 后填写
# 用法: cp .env.deploy.example .env.deploy
# 供 npm run deploy:landing 读取（本地执行，不会上传到容器）
# 运行时环境变量请复制 .env.landing.example 为 .env.landing

# Docker 镜像仓库（留空则 docker login / push 使用 Docker Hub 默认域名）
DOCKER_REGISTRY=

# 镜像仓库登录
DOCKER_USERNAME=
DOCKER_PASSWORD=

# 镜像名称与标签（可选，默认 rssany-landing:latest）
DOCKER_IMAGE_NAME=rssany-landing
DOCKER_IMAGE_TAG=latest

# 远程服务器 SSH
SSH_HOST=
SSH_PORT=22
SSH_USERNAME=
SSH_PASSWORD=

# 远程容器（可选）
REMOTE_CONTAINER_NAME=rssany-landing
REMOTE_FRONTEND_PORT=13124

# 可选：跳过本地 build/push，仅 SSH 重启容器
# DEPLOY_SKIP_IMAGE_UPDATE=false

# 可选：docker build 时拉取最新基础镜像（网络不稳时可保持 false）
# DEPLOY_DOCKER_PULL_BASE=false

# 远程 VPS 平台（默认 linux/amd64）
# DEPLOY_DOCKER_PLATFORM=linux/amd64
