# 部署凭据模板 — 复制为 .env.deploy 后填写
# 用法: cp .env.deploy.example .env.deploy
# 供 npm run deploy:landing 读取（本地执行，不会上传到容器）

# Docker 镜像仓库（留空则 docker login / push 使用 Docker Hub 默认域名）
DOCKER_REGISTRY=

# 镜像仓库登录
DOCKER_USERNAME=
DOCKER_PASSWORD=

# 镜像名称与标签（可选，默认 rssany-landing:latest）
DOCKER_IMAGE_NAME=rssany-landing
DOCKER_IMAGE_TAG=latest

# 远程服务器 SSH
SSH_HOST=
SSH_PORT=22
SSH_USERNAME=
SSH_PASSWORD=

# 远程容器（可选）
REMOTE_CONTAINER_NAME=rssany-landing
REMOTE_FRONTEND_PORT=13124